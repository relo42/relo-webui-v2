# Relo WebUI — Environment Variables
#
# Copy this to .env and adjust as needed:
#   cp .env.example .env

# ═══════════════════════════════════════════════════════════════
# REQUIRED for Docker Compose
# The hermes-agent container needs an API key to function.
# Get your key at: https://console.anthropic.com/settings/keys
# ═══════════════════════════════════════════════════════════════
ANTHROPIC_API_KEY=your-api-key-here

# ═══════════════════════════════════════════════════════════════
# Optional: Relo Agent Connection
# ═══════════════════════════════════════════════════════════════

# Relo Agent WebAPI URL (default: http://127.0.0.1:8642)
# - For Docker: Uses http://hermes-agent:8642 automatically
# - For local dev: Set to http://127.0.0.1:8642
# IMPORTANT: The Hermes gateway HTTP API server is opt-in.
# Add API_SERVER_ENABLED=true to ~/.hermes/.env and restart the gateway.
# Without it, the gateway serves messaging platforms but not port 8642.
# HERMES_API_URL=http://127.0.0.1:8642

# Relo Agent directory (auto-detected if sibling to workspace)
# Set this if hermes-agent is installed elsewhere
# RELO_AGENT_PATH=/path/to/hermes-agent

# Server port (default: 3002)
# PORT=3002

# ═══════════════════════════════════════════════════════════════
# Optional: Redis Session Persistence
# ═══════════════════════════════════════════════════════════════
# When set, portable-mode chat sessions are stored in Redis instead of
# .runtime/local-sessions.json. Both backends survive server restarts.
# Redis adds multi-device and multi-instance support.
#
# Local dev (Redis running on host):
#   REDIS_URL=redis://localhost:6379
#
# Docker (with --profile redis):
#   REDIS_URL=redis://redis:6379
#
# IMPORTANT: Leave this unset (or empty) if you are not running Redis.
# An unset REDIS_URL means "no Redis" — no connection is attempted at all.
# If set to an unreachable host, startup retries ~30s then falls back to
# the file store — the server will NOT hang or stall.
#
# REDIS_URL=
